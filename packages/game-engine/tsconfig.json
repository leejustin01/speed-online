{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "composite": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@game/types": ["../types/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../types" }]
}